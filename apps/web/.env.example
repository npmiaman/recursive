# Recursive dashboard configuration.
#
# The dashboard holds ONE model key server-side and lends it to every account
# that signs in, metering usage per account. This is the key it forwards with.
# It never leaves the server, and no laptop ever needs a model key of its own.
#
# For testing this is the free NVIDIA key (40 RPM shared across everyone). At
# launch, swap in a paid key (or point MODEL_UPSTREAM_BASE at another provider)
# and nothing on any laptop changes.
MODEL_UPSTREAM_KEY=nvapi-...
MODEL_UPSTREAM_BASE=https://integrate.api.nvidia.com

# The dashboard's own database lives in .data/ (gitignored). Nothing else to set
# for local use; deploy to Vercel and set MODEL_UPSTREAM_KEY in its dashboard.
