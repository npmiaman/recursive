# ---- Reasoning model (query expansion, reranking, investigation) ----
# SECURITY: put keys HERE, never in a chat message, ticket, or commit.
#           This file is gitignored. Rotate any key that has been pasted anywhere.
#
# anthropic (default): best quality
# openai             : OpenAI, or ANY OpenAI-compatible endpoint (Ollama, vLLM,
#                       LM Studio). Point OPENAI_BASE_URL at a self-hosted model
#                       to keep every prompt inside your own network.
LLM_PROVIDER=anthropic

# Either set ANTHROPIC_API_KEY, or run `ant auth login` and leave this unset.
ANTHROPIC_API_KEY=

# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Pace requests to a hosted free tier's cap. 0 = no pacing (the default, correct
# for OpenAI proper and self-hosted models). On a 429 the client honours the
# server's Retry-After and backs off, retrying OPENAI_MAX_RETRIES times.
OPENAI_RPM=0
OPENAI_MAX_RETRIES=4
#
# Free hosted models via NVIDIA build.nvidia.com (get an nvapi- key there, no
# card, ~1000 credits). The free tier is 40 requests/min, so set OPENAI_RPM=40
# or enrichment will trip 429s partway through indexing a large repo. Lower the
# indexer's concurrency too: `memory index --concurrency 2`.
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_MODEL=meta/llama-3.3-70b-instruct   # or a nemotron / qwen / deepseek id
#   OPENAI_API_KEY=nvapi-...
#   OPENAI_RPM=40
#
# Fully on-prem example, no key needed, nothing leaves the network:
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=qwen2.5-coder:32b

# ---- Microsoft Clarity ----
# Clarity project -> Settings -> Data Export -> Generate new API token.
# HARD LIMIT: 10 requests per project per day, 1-3 day lookback, 1000 rows, no pagination.
# Leave empty to run the whole system against generated fixtures (CLARITY_MODE=mock).
CLARITY_API_TOKEN=
CLARITY_MODE=mock          # mock | live

# ---- Target site + repo ----
# The deployed site the proxy scorer drives with a headless browser.
TARGET_BASE_URL=http://localhost:3000
# The checkout the fix agent edits. Must be a git repo with a clean tree.
TARGET_REPO_PATH=/absolute/path/to/your/site

# ---- GitHub (PR stage) ----
# Uses the `gh` CLI, so this is optional if you're already authenticated with `gh auth login`.
GITHUB_TOKEN=
PR_BASE_BRANCH=main

# ---- Code-edit engine ----
# Which agent modifies customer repositories. Run `npm run cli -- engines`.
#   claude-agent-sdk  best quality. Source stays on your infra; prompts reach the
#                     Anthropic API. Requires an API key (claude.ai login is not
#                     usable with the Agent SDK, and plan limits can't be resold).
#   openhands         MIT licensed, model-agnostic. Point OPENHANDS_BASE_URL at a
#                     self-hosted model to keep everything inside a customer's
#                     network. This is the zero-egress option.
#   native            No extra dependency. Reuses LLM_PROVIDER (so a NVIDIA
#                     free-tier model, a local Ollama, or OpenAI can write code
#                     with zero setup). Single-shot rather than agentic: it edits
#                     the retrieved files and the closed loop re-verifies, rather
#                     than grepping and running tests itself. Good default when
#                     you already have an OpenAI-compatible endpoint configured.
FIX_ENGINE=claude-agent-sdk
OPENHANDS_MODEL=anthropic/claude-opus-4-8
# OPENHANDS_BASE_URL=http://localhost:11434/v1   # e.g. a local Ollama/vLLM endpoint
# LLM_API_KEY=                                    # used by the OpenHands engine

# ---- Loop tuning ----
# Max hill-climb iterations per issue in the inner AutoResearch loop.
MAX_ITERATIONS=12
# Days to wait after a deploy before the outer loop trusts a Clarity re-sample.
VERIFY_AFTER_DAYS=3
